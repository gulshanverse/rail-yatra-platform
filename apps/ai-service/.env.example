# AI Service Configuration (FastAPI)
PORT=8000
ENV=production
REDIS_URL="redis://default:redis_secure_password@redis-host:6379"
QDRANT_URL="https://your-qdrant-cluster-id.gcp.qdrant.io:6333"
QDRANT_API_KEY="your-qdrant-read-write-api-key"
DEFAULT_PROVIDER="openai"
DEFAULT_MODEL="gpt-4o-mini"
ENABLE_MOCK_LLM=false

# LLM Providers (Configure at least one for production)
OPENAI_API_KEY="sk-proj-..."
GOOGLE_API_KEY="AIzaSy..."
ANTHROPIC_API_KEY="sk-ant-..."
