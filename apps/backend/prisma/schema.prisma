// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User roles represented as strings in the SQLite database:
// GUEST, USER, PREMIUM, PREMIUM_PLUS, MODERATOR, SUPPORT, ADMIN, SUPER_ADMIN, DEVELOPER, AUDITOR
model User {
  id            String         @id @default(uuid())
  email         String         @unique
  phone         String?        @unique
  fullName      String
  passwordHash  String
  avatar        String?
  role          String         @default("USER")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  
  settings      UserSetting?
  trips         Trip[]
  searches      SearchHistory[]
  savedRoutes   SavedRoute[]
  pnrHistory    PnrHistory[]
  conversations Conversation[]
  subscriptions Subscription[]
}

model UserSetting {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme           String   @default("auto") // light, dark, auto, high-contrast
  notifications   Boolean  @default(true)
  accessibility   Boolean  @default(false)
  voiceMode       Boolean  @default(false)
  privacyMode     Boolean  @default(false)
  aiPreferences   String?  // JSON string (SQLite compatibility)
  language        String   @default("en")   // en, hi, etc.
  travelPrefs     String?  // JSON string (SQLite compatibility)
}

model Trip {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  source       String
  destination  String
  journeyDate  DateTime
  returnDate   DateTime?
  passengers   String    // JSON string list of passenger details
  journeyType  String    @default("direct") // direct, split, etc.
  budget       Decimal?
  status       String    @default("scheduled") // scheduled, completed, cancelled
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SearchHistory {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query       String?
  source      String
  destination String
  filters     String?  // JSON string
  timestamp   DateTime @default(now())
}

model SavedRoute {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  source      String
  destination String
  frequency   String?  // daily, weekly, etc.
  reminder    Boolean  @default(false)
}

model PnrHistory {
  id           String   @id @default(uuid())
  pnr          String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prediction   String?  // JSON string prediction details, confidence, etc.
  actualStatus String   @default("unknown")
  journeyDate  DateTime
  timestamp    DateTime @default(now())
}

model Conversation {
  id         String        @id @default(uuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary    String?
  messages   ChatMessage[]
  context    String?       // JSON string key-value store for AI session state
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model ChatMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // user, assistant, system
  content        String
  tokensUsed     Int?
  timestamp      DateTime     @default(now())
}

// Subscription tiers represented as strings: FREE, PREMIUM, PREMIUM_PLUS
model Subscription {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier      String           @default("FREE")
  expiry    DateTime?
  status    String           @default("active") // active, expired, cancelled
  credits   Int              @default(3)        // AI journey analysis quota per month
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String   @unique
  userId    String
  gateway   String   // razorpay, stripe, etc.
  amount    Decimal
  currency  String   @default("INR")
  status    String   // completed, failed, pending
  createdAt DateTime @default(now())
}

model Invoice {
  id            String   @id @default(uuid())
  paymentId     String?
  userId        String
  invoiceNumber String   @unique
  pdfUrl        String?
  amount        Decimal
  currency      String   @default("INR")
  status        String   @default("paid") // paid, void, refunded
  createdAt     DateTime @default(now())
}

model UsageLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // ai_message, journey_analysis, pnr_check, recommendation_request
  timestamp DateTime @default(now())
}

model BillingEvent {
  id          String   @id @default(uuid())
  userId      String
  eventType   String   // payment_success, payment_failed, subscription_renewed, subscription_cancelled
  payload     String   // JSON string of event body
  timestamp   DateTime @default(now())
}
