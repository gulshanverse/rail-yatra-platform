// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// User roles represented as strings in the SQLite database:
// GUEST, USER, PREMIUM, PREMIUM_PLUS, MODERATOR, SUPPORT, ADMIN, SUPER_ADMIN, DEVELOPER, AUDITOR
model User {
  id            String         @id @default(uuid())
  email         String         @unique
  phone         String?        @unique
  fullName      String
  passwordHash  String
  avatar        String?
  role          String         @default("USER")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  
  settings      UserSetting?
  trips         Trip[]
  searches      SearchHistory[]
  savedRoutes   SavedRoute[]
  pnrHistory    PnrHistory[]
  conversations Conversation[]
  subscriptions Subscription[]
}

model UserSetting {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme           String   @default("auto") // light, dark, auto, high-contrast
  notifications   Boolean  @default(true)
  accessibility   Boolean  @default(false)
  voiceMode       Boolean  @default(false)
  privacyMode     Boolean  @default(false)
  aiPreferences   String?  // JSON string (SQLite compatibility)
  language        String   @default("en")   // en, hi, etc.
  travelPrefs     String?  // JSON string (SQLite compatibility)
}

model Trip {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  source       String
  destination  String
  journeyDate  DateTime
  returnDate   DateTime?
  passengers   String    // JSON string list of passenger details
  journeyType  String    @default("direct") // direct, split, etc.
  budget       Decimal?
  status       String    @default("scheduled") // scheduled, completed, cancelled
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model SearchHistory {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  query       String?
  source      String
  destination String
  filters     String?  // JSON string
  timestamp   DateTime @default(now())
}

model SavedRoute {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  source      String
  destination String
  frequency   String?  // daily, weekly, etc.
  reminder    Boolean  @default(false)
}

model PnrHistory {
  id           String   @id @default(uuid())
  pnr          String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  prediction   String?  // JSON string prediction details, confidence, etc.
  actualStatus String   @default("unknown")
  journeyDate  DateTime
  timestamp    DateTime @default(now())
}

model Conversation {
  id         String        @id @default(uuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary    String?
  messages   ChatMessage[]
  context    String?       // JSON string key-value store for AI session state
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model ChatMessage {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // user, assistant, system
  content        String
  tokensUsed     Int?
  timestamp      DateTime     @default(now())
}

// Subscription tiers represented as strings: FREE, PREMIUM, PREMIUM_PLUS
model Subscription {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier      String           @default("FREE")
  expiry    DateTime?
  status    String           @default("active") // active, expired, cancelled
  credits   Int              @default(3)        // AI journey analysis quota per month
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String   @unique
  userId    String
  gateway   String   // razorpay, stripe, etc.
  amount    Decimal
  currency  String   @default("INR")
  status    String   // completed, failed, pending
  createdAt DateTime @default(now())
}

model Invoice {
  id            String   @id @default(uuid())
  paymentId     String?
  userId        String
  invoiceNumber String   @unique
  pdfUrl        String?
  amount        Decimal
  currency      String   @default("INR")
  status        String   @default("paid") // paid, void, refunded
  createdAt     DateTime @default(now())
}

model UsageLog {
  id        String   @id @default(uuid())
  userId    String
  action    String   // ai_message, journey_analysis, pnr_check, recommendation_request
  timestamp DateTime @default(now())
}

model BillingEvent {
  id          String   @id @default(uuid())
  userId      String
  eventType   String   // payment_success, payment_failed, subscription_renewed, subscription_cancelled
  payload     String   // JSON string of event body
  timestamp   DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  category  String   @default("System") // Journey, PNR, AI, Billing, Marketing, System
  priority  String   @default("medium") // low, medium, high, critical
  read      Boolean  @default(false)
  channel   String   // email, sms, push, whatsapp
  timestamp DateTime @default(now())
}

model NotificationPreference {
  id              String  @id @default(uuid())
  userId          String  @unique
  emailAlerts    Boolean @default(true)
  smsAlerts      Boolean @default(false)
  pushAlerts     Boolean @default(true)
  whatsappAlerts Boolean @default(false)
  quietHoursStart String @default("22:00") // HH:MM format
  quietHoursEnd   String @default("06:00")
  marketingAlerts Boolean @default(false)
  digestPreference String @default("instant") // instant, daily_digest, weekly_digest
}

model ReminderSchedule {
  id           String   @id @default(uuid())
  userId       String
  title        String
  description  String
  triggerTime  DateTime
  status       String   @default("pending") // pending, sent, failed
  reminderType String   // journey_preparation, booking_window, subscription_expiry
  metadata     String?  // JSON string parameters
}

model UserInsight {
  id        String   @id @default(uuid())
  userId    String
  title     String
  content   String   // AI-generated personalization travel recommendation summary
  timestamp DateTime @default(now())
}

model DeliveryLog {
  id        String   @id @default(uuid())
  userId    String
  channel   String
  status    String   // success, failed
  errorMsg  String?
  timestamp DateTime @default(now())
}

model EngagementScore {
  id            String   @id @default(uuid())
  userId        String   @unique
  score         Int      @default(0)
  lastTriggered DateTime @default(now())
}

model AuditLog {
  id               String   @id @default(uuid())
  actorId          String
  actorEmail       String
  action           String   // toggle_feature_flag, update_system_config, etc.
  requestId        String?
  ipAddress        String?
  userAgent        String?
  affectedResource String?
  actionResult     String   @default("success") // success, failed
  details          String   // JSON string of differences
  timestamp        DateTime @default(now())
}

model SystemMetric {
  id            String   @id @default(uuid())
  nodeName      String   // api_server, database, redis, ai_service, background_worker
  status        String   // healthy, degraded, critical
  cpuPercent    Float    @default(0.0)
  memoryBytes   Decimal  @default(0)
  latencyMs     Int      @default(0)
  cacheHitRatio Float    @default(1.0)
  queueLength   Int      @default(0)
  timestamp     DateTime @default(now())
}

model PlatformEvent {
  id        String   @id @default(uuid())
  type      String   // user_login, subscription_purchase, etc.
  details   String?  // JSON context
  timestamp DateTime @default(now())
}

model AnalyticsSnapshot {
  id               String   @id @default(uuid())
  date             String   @unique // YYYY-MM-DD
  activeUsersCount Int      @default(0)
  aiMessagesCount  Int      @default(0)
  analysesCount    Int      @default(0)
  revenueAmount    Decimal  @default(0)
  retentionRate    Float    @default(100.0)
  conversionRatio  Float    @default(0.0)
  timestamp        DateTime @default(now())
}

model FeatureFlag {
  id          String   @id @default(uuid())
  name        String   @unique
  enabled     Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
}

model SystemConfiguration {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}
